{
  "commands": [
    {
      "name": "Launch",
      "identifier": "browse-components",
      "script": "symbol-browser.js",
      "handler": "onRun",
      "shortcut": "cmd shift ;"
    },
    {
      "name": "Settings",
      "identifier": "open-settings",
      "script": "symbol-browser.js",
      "handler": "onRunSettings"
    },
    {
      "identifier": "component-browser-agent",
      "script": "symbol-browser.js",
      "handlers": {
        "actions": {
          "Startup": "onStartup",
          "Shutdown": "onShutdown"
        }
      }
    }
  ],
  "name": "🧭 Component Browser",
  "identifier": "com.funkyplugins.componentbrowser",
  "version": "1.4.1",
  "appcast": "https://raw.githubusercontent.com/funk4d/Component-Browser-Sketch-Plugin/main/appcast.json",
  "description": "Browse and insert Symbols/Components",
  "author": "Dmytro Shevchuk",
  "icon": "icon.png",
  "compatibleVersion": 3,
  "bundleVersion": 2,
  "menu": {
    "title": "🧭 Component Browser",
    "items": [
      "browse-components",
      "open-settings"
    ]
  },
  "disableCocoaScriptPreprocessor": true
}
